# Supabase pooled connection (Transaction pooler, usually port 6543)
# Add pgbouncer=true and connection_limit=1 for Prisma runtime stability.
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@<POOLER_HOST>:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Supabase direct connection (usually port 5432) used by Prisma db push/migrations/seed.
DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require"

# Workspace + actor defaults (used for tenancy scoping in app services and seed data).
APP_WORKSPACE_SLUG="aurora-main"
APP_WORKSPACE_NAME="Aurora Main Workspace"
APP_ACTOR_EMAIL="rep@aurora.local"
APP_ACTOR_NAME="Default Rep"

# Auth.js secret (generate with: `openssl rand -base64 32`)
AUTH_SECRET=""

# OAuth providers (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_LINKEDIN_ID=""
AUTH_LINKEDIN_SECRET=""

# Enable credentials-based dev login page.
# Keep this "0" in production unless explicitly needed.
APP_ENABLE_DEV_LOGIN="1"

# Public app URL used for metadata/share previews (LinkedIn/Open Graph).
APP_BASE_URL="https://your-domain.com"

# Optional: enable route-level performance logging in server console.
# Logs look like: [perf] route=/cockpit phase=dashboard_data duration_ms=42.7
APP_PERF_LOGS="1"

# Optional: strategy generation timeout in milliseconds.
APP_AI_STRATEGY_TIMEOUT_MS="900"

# Optional: auto-create workspace memberships for signed-in users not yet present in workspace_members.
# Set to "0" to require explicit member provisioning.
APP_AUTO_PROVISION_MEMBERS="1"

# OpenAI API key for AI-powered strategy generation.
# If not set, falls back to rule-based strategy plays.
OPENAI_API_KEY=""
