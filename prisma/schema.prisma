generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Workspace {
  id        String            @id @default(cuid())
  slug      String            @unique
  name      String
  members   WorkspaceMember[]
  accounts  Account[]
  syncStates IntegrationSyncState[]
  notifications SignalNotification[]
  sequenceExecutions SequenceExecution[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  fullName    String
  role        String              @default("REP")
  preferences UserPreference?
  aiUsageDaily AiUsageDaily[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([workspaceId, email])
  @@index([workspaceId])
}

model UserPreference {
  id                    String          @id @default(cuid())
  workspaceMemberId     String          @unique
  workspaceMember       WorkspaceMember @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)
  themePreference       String          @default("system")
  timezone              String          @default("UTC")
  locale                String          @default("en-US")
  weekStartsOn          String          @default("monday")
  compactMode           Boolean         @default(false)
  reduceMotion          Boolean         @default(false)
  emailNotifications    Boolean         @default(true)
  desktopNotifications  Boolean         @default(true)
  mentionNotifications  Boolean         @default(true)
  pipelineAlerts        Boolean         @default(true)
  approvalQueueAlerts   Boolean         @default(true)
  dailyDigest           Boolean         @default(false)
  digestHour            Int             @default(8)
  loginAlerts           Boolean         @default(true)
  productAnnouncements  Boolean         @default(true)
  aiApiKey              String?
  aiModel               String          @default("gpt-5.4-mini-2026-03-17")
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([workspaceMemberId])
}

model Account {
  id           String         @id @default(cuid())
  workspaceId   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  externalId   String?        @unique
  name         String
  segment      String
  website      String?
  employeeBand String?
  contacts     Contact[]
  deals        Deal[]
  signals      Signal[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([workspaceId])
}

model Contact {
  id         String          @id @default(cuid())
  externalId String?         @unique
  accountId  String
  account    Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  fullName   String
  title      String
  email      String?
  linkedIn   String?
  role       String
  sequenceExecutions SequenceExecution[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([accountId])
}

model Deal {
  id           String         @id @default(cuid())
  externalId   String?        @unique
  accountId    String
  account      Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name         String
  stage        String
  amount       Int
  confidence   Float
  closeDate    DateTime
  riskSummary  String
  tasks        Task[]
  activities   Activity[]
  calendarEvents CalendarEvent[]
  auditLogs    AuditLog[]
  outboundApprovals OutboundApproval[]
  signalNotifications SignalNotification[]
  sequenceExecutions SequenceExecution[]
  meetingBrief MeetingBrief?
  followUp     FollowUpDraft?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([accountId])
  @@index([stage])
}

model Signal {
  id         String     @id @default(cuid())
  externalId String?    @unique
  accountId  String
  account    Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type       String
  summary    String
  happenedAt DateTime
  score      Int
  notifications SignalNotification[]
  createdAt  DateTime   @default(now())

  @@index([accountId])
  @@index([happenedAt])
}

model Activity {
  id         String       @id @default(cuid())
  externalId String?      @unique
  dealId     String
  deal       Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type       String
  happenedAt DateTime
  summary    String
  createdAt  DateTime     @default(now())

  @@index([dealId])
  @@index([happenedAt])
}

model Task {
  id               String           @id @default(cuid())
  externalId       String?          @unique
  dealId           String
  deal             Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title            String
  owner            String
  dueAt            DateTime
  priority         String
  status           String
  suggestedChannel String
  completedAt      DateTime?
  auditLogs        AuditLog[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([dealId])
  @@index([status])
  @@index([dueAt])
}

model CalendarEvent {
  id             String   @id @default(cuid())
  externalId     String?  @unique
  dealId         String
  deal           Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title          String
  startsAt       DateTime
  endsAt         DateTime
  organizerEmail String?
  attendees      String   @default("")
  source         String
  createdAt      DateTime @default(now())

  @@index([dealId])
  @@index([startsAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  dealId     String
  deal       Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  entityType String
  entityId   String
  action     String
  actor      String
  details    String
  createdAt  DateTime @default(now())

  @@index([dealId])
  @@index([taskId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model MeetingBrief {
  id                   String   @id @default(cuid())
  dealId               String   @unique
  deal                 Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  primaryGoal          String
  likelyObjections     String   @default("[]")
  recommendedNarrative String
  proofPoints          String   @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model FollowUpDraft {
  id            String   @id @default(cuid())
  dealId        String   @unique
  deal          Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  subject       String
  body          String
  ask           String
  ctaTimeWindow String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OutboundApproval {
  id              String         @id @default(cuid())
  dealId           String
  deal             Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  channel          String
  subject          String
  body             String
  status           String         @default("PENDING")
  requestedBy      String
  reviewedBy       String?
  reviewedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([dealId, status])
  @@index([createdAt])
}

model IntegrationSyncState {
  id          String              @id @default(cuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider    String
  cursor      String?
  status      String              @default("idle")
  lastRunAt   DateTime?
  lastError   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([workspaceId, provider])
  @@index([workspaceId, updatedAt])
}

model SignalNotification {
  id               String             @id @default(cuid())
  workspaceId      String
  workspace        Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signalId         String
  signal           Signal             @relation(fields: [signalId], references: [id], onDelete: Cascade)
  dealId           String?
  deal             Deal?              @relation(fields: [dealId], references: [id], onDelete: SetNull)
  priority         String
  summary          String
  recommendedAction String
  status           String             @default("UNREAD")
  acknowledgedAt   DateTime?
  acknowledgedBy   String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([workspaceId, signalId])
  @@index([workspaceId, status, createdAt])
  @@index([dealId])
}

model SequenceExecution {
  id           String                  @id @default(cuid())
  workspaceId  String
  workspace    Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dealId       String
  deal                 Deal                    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contactId    String?
  contact      Contact?                @relation(fields: [contactId], references: [id], onDelete: SetNull)
  title        String
  channelMix   String                  @default("")
  status       String                  @default("ACTIVE")
  createdBy    String
  steps        SequenceStep[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([workspaceId, status, createdAt])
  @@index([dealId])
}

model SequenceStep {
  id           String             @id @default(cuid())
  executionId  String
  execution    SequenceExecution  @relation(fields: [executionId], references: [id], onDelete: Cascade)
  order        Int
  channel      String
  instruction  String
  status       String             @default("TODO")
  outcome      String?
  completedAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([executionId, order])
  @@index([status, createdAt])
}

model AiUsageDaily {
  id                String          @id @default(cuid())
  workspaceMemberId String
  workspaceMember   WorkspaceMember @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)
  date              DateTime
  model             String
  totalTokens       Int             @default(0)
  promptTokens      Int             @default(0)
  completionTokens  Int             @default(0)
  requestCount      Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([workspaceMemberId, date, model])
  @@index([workspaceMemberId, date])
}
