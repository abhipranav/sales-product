{
  "manifest_version": 3,
  "name": "Velocity LinkedIn Companion",
  "version": "1.0.0",
  "description": "Capture LinkedIn profiles and companies into Velocity CRM with AI-powered enrichment.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*", "https://linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Velocity LinkedIn Companion"
  }
}
